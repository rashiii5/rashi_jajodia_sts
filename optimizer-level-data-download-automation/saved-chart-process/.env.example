# ─────────────────────────────────────────────
# SolarEdge Automation — Environment Variables
# Copy this file to .env and fill in your values
# NEVER commit .env to version control
# ─────────────────────────────────────────────

# ── SolarEdge API ────────────────────────────
# Your installer API key from the SolarEdge monitoring portal
SE_API_KEY=YOUR_API_KEY

# Base URL — do not change unless SolarEdge updates it
SE_API_BASE=https://monitoringapi.solaredge.com

# ── Site Filtering ────────────────────────────
# The group name shown in the monitoring platform filter
# Change this to match exactly what appears in the "Group" dropdown
SE_GROUP_NAME=STS Installed

# ── Browser Profile ───────────────────────────
# Path where Chrome stores your persistent login session
# Use an absolute path; ~ is supported on Linux/macOS
# On Windows use: C:\Users\YourName\.solaredge-profile
SE_PROFILE_DIR=~/.solaredge-browser-profile

# ── Downloads ─────────────────────────────────
# Where exported CSVs land on your machine (relative or absolute)
SE_DOWNLOAD_DIR=./downloads

# ── Behaviour ─────────────────────────────────
# Show the browser window while running (true = visible, false = headless)
# Keep true until you've confirmed everything works correctly
SE_HEADLESS=false

# Milliseconds of artificial delay between actions (humanises clicks)
# Increase if SolarEdge rate-limits or shows CAPTCHA
SE_SLOW_MO=300

# How many times to retry a failed site before skipping it
SE_MAX_RETRIES=3
